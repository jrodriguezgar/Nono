{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sentiment Analysis Output",
  "type": "object",
  "required": ["sentiment", "confidence", "emotion", "tone", "intensity"],
  "properties": {
    "sentiment": {
      "type": "string",
      "enum": ["positive", "negative", "neutral", "mixed"],
      "description": "Overall sentiment polarity."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score for the sentiment classification."
    },
    "emotion": {
      "type": "string",
      "enum": ["joy", "anger", "sadness", "fear", "surprise", "disgust", "trust", "anticipation"],
      "description": "Primary emotion detected (Plutchik's wheel)."
    },
    "tone": {
      "type": "string",
      "description": "Communication tone (e.g., enthusiastic, sarcastic, formal)."
    },
    "intensity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Sentiment intensity on a 1-5 scale."
    },
    "sarcasm_detected": {
      "type": "boolean",
      "description": "Whether sarcasm or irony was detected."
    },
    "language": {
      "type": "string",
      "description": "Detected language (ISO 639-1 code)."
    },
    "notes": {
      "type": "string",
      "description": "Additional observations."
    }
  }
}
